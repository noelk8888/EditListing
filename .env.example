# Google OAuth (for user login)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Google Sheets API (service account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=your_service_account@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
SPREADSHEET_ID=1T-LUc3cKn0ojq1p3VvgpFs4NzB8Z6ZKV4iJaoEhfwKM

# Claude API
ANTHROPIC_API_KEY=sk-ant-your_key_here

# NextAuth
NEXTAUTH_SECRET=generate_a_random_secret_here
NEXTAUTH_URL=http://localhost:3000

# User Roles — comma-separated Google emails granted SUPERADMIN access
# These users bypass the app_users table and always have full access
SUPERADMIN_EMAILS=your_email@gmail.com

# Optional: Google Geocoding API (for lat/long)
GOOGLE_GEOCODING_API_KEY=your_geocoding_api_key

# Optional: Telegram notifications (send col A text on listing save/update)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id_or_group_id
